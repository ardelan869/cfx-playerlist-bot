{
  "name": "discord-js-boilerplate",
  "module": "./src/index.ts",
  "main": "./src/index.ts",
  "type": "module",
  "scripts": {
    "build": "rollup -c && node scripts/fix-json-imports.js",
    "dev": "nodemon ./src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint .",
